{
  "expo": {
    "name": "Students Traffic",
    "slug": "students-traffic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "studentstraffic",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f3d37"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studentstraffic.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Students Traffic needs microphone access for voice calls with student guides."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f3d37",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#0f3d37",
          "sounds": [],
          "iosDisplayInForeground": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "ad3c91c1-1c05-485b-9c90-78d71f0ebc36"
      }
    },
    "owner": "bharathv"
  }
}
