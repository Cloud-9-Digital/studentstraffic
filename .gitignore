# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
/.indexnow/
/.tmp/
/tmp/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
public/guides/raster/
.env*.local

# Android Studio / IntelliJ project metadata
.idea/
mobile/app/.idea/

# Local Codex/browser verification artefacts
.codex-dev-*.log
/outputs/

# Publishing media is uploaded to Cloudinary; keep only durable payloads/reports
/research/media/
/research/catalog-media/
/research/catalog-payloads/

# One-off local publishing helpers
/scripts/_dry-*
/scripts/_tmp-*
